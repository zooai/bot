{
  "gateway": {
    "auth": {
      "mode": "token"
    },
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:8080",
        "http://localhost:18789",
        "http://localhost:3000"
      ],
      "allowInsecureAuth": true,
      "dangerouslyDisableDeviceAuth": true,
      "basePath": "/__bot__"
    },
    "nodes": {
      "allowCommands": [
        "chat.send",
        "chat.abort",
        "status.get",
        "exec.run",
        "exec.approve",
        "session.checkpoint",
        "session.restore",
        "session.list"
      ]
    }
  },
  "agents": {
    "defaults": {
      "model": "hanzo/claude-sonnet-4-6"
    }
  }
}
