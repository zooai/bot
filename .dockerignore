# build artifacts
dist
**/dist
apps/macos/.build
apps/ios/build
**/*.trace

# Admin SPA: synced from gui workspace by scripts/sync-admin-ui.sh
# before docker build. The Node static handler in
# src/gateway/control-ui.ts reads dist/control-ui/ at runtime, so the
# image MUST include this directory. The general `dist` exclude above
# would otherwise drop it from the build context.
!dist/control-ui
!dist/control-ui/**

# large app trees not needed for CLI build
apps/
assets/
Peekaboo/
Swabble/
Core/
Users/
vendor/

# Needed for building the Canvas A2UI bundle during Docker image builds.
# Keep the rest of apps/ and vendor/ excluded to avoid a large build context.
!apps/shared/
!apps/shared/ZooBotKit/
!apps/shared/ZooBotKit/Sources/
!apps/shared/ZooBotKit/Sources/ZooBotKit/
!apps/shared/ZooBotKit/Sources/ZooBotKit/Resources/
!apps/shared/ZooBotKit/Sources/ZooBotKit/Resources/tool-display.json
!apps/shared/ZooBotKit/Tools/
!apps/shared/ZooBotKit/Tools/CanvasA2UI/
!apps/shared/ZooBotKit/Tools/CanvasA2UI/**
!vendor/a2ui/
!vendor/a2ui/renderers/
!vendor/a2ui/renderers/lit/
!vendor/a2ui/renderers/lit/**
