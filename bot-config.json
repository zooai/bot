{
  "canvasHost": {
    "liveReload": false
  },
  "agents": {
    "defaults": {
      "model": "anthropic/claude-sonnet-4-6"
    }
  },
  "models": {
    "providers": {
      "anthropic": {
        "baseUrl": "https://api.zoo.network",
        "api": "anthropic-messages",
        "models": []
      }
    }
  },
  "gateway": {
    "controlUi": {
      "allowedOrigins": ["http://localhost:18789", "http://localhost:3000"],
      "allowInsecureAuth": true,
      "dangerouslyDisableDeviceAuth": true,
      "basePath": "/__bot__"
    }
  }
}
